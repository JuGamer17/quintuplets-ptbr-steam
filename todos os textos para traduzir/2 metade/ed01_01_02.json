    },
    {
      "id": 38,
      "personagem": "Ichika",
      "texto_en": "Ah, alright.",
      "texto_ptbr": ""
    },
    {
      "id": 39,
      "personagem": "Ichika",
      "texto_en": " Enjoy the photo, okay?]",
      "texto_ptbr": ""
    },
    {
      "id": 40,
