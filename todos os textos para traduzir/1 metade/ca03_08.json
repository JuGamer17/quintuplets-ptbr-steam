  "dialogos": [
    {
      "id": 0,
      "personagem": "Miku",
      "texto_en": "*sigh*",
      "texto_ptbr": ""
    },
    {
      "id": 1,
      "personagem": "Miku",
      "texto_en": "What are you doing, Miku.\\nThis isn't how it was supposed to go.",
      "texto_ptbr": ""
    },
    {
      "id": 2,
      "personagem": "Itsuki",
      "texto_en": "Miku?",
      "texto_ptbr": ""
    },
    {
      "id": 3,
      "personagem": "Miku",
      "texto_en": "Oh, Itsuki.\\nAre you done exploring the exhibition?",
      "texto_ptbr": ""
    },
    {
      "id": 4,
      "personagem": "Itsuki",
      "texto_en": "Yes, I enjoyed learning about\\nOkinawan culture and history.\\nWhere is everyone else?",
      "texto_ptbr": ""
    },
    {
      "id": 5,
      "personagem": "Miku",
      "texto_en": "Yotsuba is in the restroom.\\nThe others might still be looking around.",
      "texto_ptbr": ""
    },
    {
      "id": 6,
      "personagem": "Itsuki",
      "texto_en": "I see.",
      "texto_ptbr": ""
    },
    {
      "id": 7,
      "personagem": "Itsuki",
      "texto_en": "......",
      "texto_ptbr": ""
    },
    {
      "id": 8,
      "personagem": "Itsuki",
      "texto_en": "Miku, um...",
      "texto_ptbr": ""
    },
    {
      "id": 9,
      "personagem": "Miku",
      "texto_en": "What?",
      "texto_ptbr": ""
    },
    {
      "id": 10,
      "personagem": "Itsuki",
      "texto_en": "...You can tell us, you know?",
      "texto_ptbr": ""
    },
    {
      "id": 11,
      "personagem": "Miku",
      "texto_en": "Huh?",
      "texto_ptbr": ""
    },
    {
      "id": 12,
      "personagem": "Itsuki",
      "texto_en": "It's about Uesugi-kun.",
      "texto_ptbr": ""
    },
    {
      "id": 13,
      "personagem": "Miku",
      "texto_en": "EH?!\\nWhy Futaro?\\nWhat did Futaro do?",
      "texto_ptbr": ""
    },
    {
      "id": 14,
      "personagem": "Itsuki",
      "texto_en": "So, Uesugi-kun is the cause of your worries\\nafter all, huh, Miku.",
      "texto_ptbr": ""
    },
    {
      "id": 15,
      "personagem": "Miku",
      "texto_en": "......",
      "texto_ptbr": ""
    },
    {
      "id": 16,
      "personagem": "Miku",
      "texto_en": "Have the others noticed too?",
      "texto_ptbr": ""
    },
    {
      "id": 17,
      "personagem": "Itsuki",
      "texto_en": "Of course.\\nWe're sisters, after all.",
      "texto_ptbr": ""
    },
    {
      "id": 18,
      "personagem": "Miku",
      "texto_en": "Ooohh...",
      "texto_ptbr": ""
    },
    {
      "id": 19,
      "personagem": "Itsuki",
      "texto_en": "We're all trying not to put any pressure on you\\nby pretending to act normal, but%p-2;――",
      "texto_ptbr": ""
    },
    {
      "id": 20,
      "personagem": "Itsuki",
      "texto_en": "I'm not good at trying to be sly,\\nso I thought I'd just ask.",
      "texto_ptbr": ""
    },
    {
      "id": 21,
      "personagem": "Miku",
      "texto_en": "Itsuki...",
      "texto_ptbr": ""
    },
    {
      "id": 22,
      "personagem": "Itsuki",
      "texto_en": "Why are you avoiding Uesugi-kun?\\nI thought you'd would be touring\\nthe castle and museum with him.",
      "texto_ptbr": ""
    },
    {
      "id": 23,
      "personagem": "Itsuki",
      "texto_en": "Uesugi-kun wants to do that, but\\nyou keep running away, right?",
      "texto_ptbr": ""
    },
    {
      "id": 24,
      "personagem": "Miku",
      "texto_en": "Yeah...",
      "texto_ptbr": ""
    },
    {
      "id": 25,
      "personagem": "Itsuki",
      "texto_en": "You guys are dating.\\nSo it's natural to behave like a couple.\\nSo you don't have to feel shy about it in front of us.",
      "texto_ptbr": ""
    },
    {
      "id": 26,
      "personagem": "Itsuki",
      "texto_en": "Ah, of course, with moderation!",
      "texto_ptbr": ""
    },
    {
      "id": 27,
      "personagem": "Miku",
      "texto_en": "......",
      "texto_ptbr": ""
    },
    {
      "id": 28,
      "personagem": "Miku",
      "texto_en": "I want to do romantic things with him, too.\\nBut if Futaro...",
      "texto_ptbr": ""
    },
    {
      "id": 29,
      "personagem": "Itsuki",
      "texto_en": "...Did something happen\\nbetween you and Uesugi-kun?",
      "texto_ptbr": ""
    },
    {
      "id": 30,
      "personagem": "Miku",
      "texto_en": "It's not like that.\\nIt's not Futaro's fault%p-2;――",
      "texto_ptbr": ""
    },
    {
      "id": 31,
      "personagem": "Yotsuba",
      "texto_en": "Sorry to keep you waaaiting!",
      "texto_ptbr": ""
    },
    {
      "id": 32,
      "personagem": "Miku",
      "texto_en": "%p-2;――%p;!",
      "texto_ptbr": ""
    },
    {
      "id": 33,
      "personagem": "Yotsuba",
      "texto_en": "Oh?\\nItsuki's here too.\\nDid you enjoy the exhibit?",
      "texto_ptbr": ""
    },
    {
      "id": 34,
      "personagem": "Itsuki",
      "texto_en": "Y-yes...",
      "texto_ptbr": ""
    },
    {
      "id": 35,
      "personagem": "Yotsuba",
      "texto_en": "Ah, everyone's here!",
      "texto_ptbr": ""
    },
    {
      "id": 36,
      "personagem": "Nino",
      "texto_en": "You guys are quite early.\\nDid you look around properly?",
      "texto_ptbr": ""
    },
    {
      "id": 37,
      "personagem": "Ichika",
      "texto_en": "Are you serious, Nino?",
      "texto_ptbr": ""
    },
    {
      "id": 38,
      "personagem": "Nino",
      "texto_en": "What? I was properly looking around, wasn't I?",
      "texto_ptbr": ""
    },
    {
      "id": 39,
      "personagem": "Raiha",
      "texto_en": "Are we the last ones?",
      "texto_ptbr": ""
    },
    {
      "id": 40,
      "personagem": "Futaro",
      "texto_en": "Yep, everyone's here now.\\nAlright, shall we finally head to the special exhibit\\nthat Miku's been waiting for?",
      "texto_ptbr": ""
    },
    {
      "id": 41,
      "personagem": "Miku",
      "texto_en": "O-okay...",
      "texto_ptbr": ""
    },
    {
      "id": 42,
      "personagem": "Itsuki",
      "texto_en": "......",
      "texto_ptbr": ""
    },
    {
      "id": 43,
      "personagem": "Yotsuba",
      "texto_en": "Hey, Itsuki.\\nDid I interrupt your conversation earlier?\\nIf so, I'm sorry...",
      "texto_ptbr": ""
    },
    {
      "id": 44,
      "personagem": "Itsuki",
      "texto_en": "No, it's fine.\\nLet's go already.",
      "texto_ptbr": ""
    }
  ]
}