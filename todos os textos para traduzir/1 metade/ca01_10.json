  "dialogos": [
    {
      "id": 0,
      "personagem": "Futaro",
      "texto_en": "Oh, you finally came back. What were you doing?",
      "texto_ptbr": ""
    },
    {
      "id": 1,
      "personagem": "Nino",
      "texto_en": "There was a shop over there that caught my attention.",
      "texto_ptbr": ""
    },
    {
      "id": 2,
      "personagem": "Futaro",
      "texto_en": "Well, why didn't you just go with everyone else?",
      "texto_ptbr": ""
    },
    {
      "id": 3,
      "personagem": "Yotsuba",
      "texto_en": "Well, it was a lingerie shop.\\nI figured it might not be appropriate for you,\\nUesugi-san.",
      "texto_ptbr": ""
    },
    {
      "id": 4,
      "personagem": "Futaro",
      "texto_en": "Linger—?!",
      "texto_ptbr": ""
    },
    {
      "id": 5,
      "personagem": "Futaro",
      "texto_en": "D-don't tell me you guys are pulling my leg again?",
      "texto_ptbr": ""
    },
    {
      "id": 6,
      "personagem": "Miku",
      "texto_en": "It IS a necessity of life, you know.",
      "texto_ptbr": ""
    },
    {
      "id": 7,
      "personagem": "Futaro",
      "texto_en": "I-I see...",
      "texto_ptbr": ""
    },
    {
      "id": 8,
      "personagem": "Ichika",
      "texto_en": "(Right, now's my chance%p-2;――%p;)",
      "texto_ptbr": ""
    },
    {
      "id": 9,
      "personagem": "Ichika",
      "texto_en": "Itsuki-chan, can I talk to you for a second?",
      "texto_ptbr": ""
    },
    {
      "id": 10,
      "personagem": "Itsuki",
      "texto_en": "What is it?",
      "texto_ptbr": ""
    },
    {
      "id": 11,
      "personagem": "Ichika",
      "texto_en": "Actually%p-2;――",
      "texto_ptbr": ""
    },
    {
      "id": 12,
      "personagem": "Itsuki",
      "texto_en": "...I understand.\\nIf everyone else is already okay with it,\\nthen I don't mind.",
      "texto_ptbr": ""
    },
    {
      "id": 13,
      "personagem": "Ichika",
      "texto_en": "Thanks, Itsuki-chan.\\nSo, shall we%p-2;――",
      "texto_ptbr": ""
    },
    {
      "id": 14,
      "personagem": "Futaro",
      "texto_en": "Hey, I think it's about time we move on.",
      "texto_ptbr": ""
    },
    {
      "id": 15,
      "personagem": "Ichika",
      "texto_en": "Wah?!\\nFutaro-kun?!",
      "texto_ptbr": ""
    },
    {
      "id": 16,
      "personagem": "Futaro",
      "texto_en": "What were you two talking about?\\nIs there somewhere you want to go?",
      "texto_ptbr": ""
    },
    {
      "id": 17,
      "personagem": "Itsuki",
      "texto_en": "W-well, um%p-2;――",
      "texto_ptbr": ""
    },
    {
      "id": 18,
      "personagem": "Ichika",
      "texto_en": "We were just talking about how we're getting hungry.",
      "texto_ptbr": ""
    },
    {
      "id": 19,
      "personagem": "Futaro",
      "texto_en": "Ah, I get it.",
      "texto_ptbr": ""
    },
    {
      "id": 20,
      "personagem": "Itsuki",
      "texto_en": "Wha?!\\nWhy are you nodding at me like that?!",
      "texto_ptbr": ""
    },
    {
      "id": 21,
      "personagem": "Futaro",
      "texto_en": "It goes without saying. I understand.",
      "texto_ptbr": ""
    },
    {
      "id": 22,
      "personagem": "Itsuki",
      "texto_en": "I-I don't know what you're talking about!\\nDon't look at me like that!",
      "texto_ptbr": ""
    },
    {
      "id": 23,
      "personagem": "Ichika",
      "texto_en": "(Ahaha...\\n Sorry, Itsuki-chan.)",
      "texto_ptbr": ""
    }
  ]
}